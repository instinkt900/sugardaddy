# Connection + paths for the sugardaddy-review Claude skill.
#
# Copy to connection.env (same directory) and fill in your values. The real
# connection.env is machine-local and MUST NOT be committed — only this
# .example file is tracked. deploy/install-skill.sh seeds it for you.

# ssh target for the Docker serve host running sugardaddy.
SD_REVIEW_HOST=your-serve-host.example

# Name of the sugardaddy container on that host.
SD_REVIEW_CONTAINER=sugardaddy

# Path to the SQLite DB inside the container (matches [database].path in config).
SD_REVIEW_DB_IN_CONTAINER=/data/sugardaddy.db

# Local clone of this repo (where `.venv` and `config.toml` live).
SD_REVIEW_REPO=$HOME/Development/sugardaddy
